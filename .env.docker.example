# Copy to .env in the repository root, then run:
#   docker compose up --build
#
# Generate a strong JWT secret, e.g.:
#   openssl rand -base64 48

JWT_SECRET=change_me_long_random_jwt_secret_at_least_32_characters

WEB_PORT=8080
WEB_ORIGIN=http://localhost:8080

SEED_ADMIN_EMAIL=admin@template.local
SEED_ADMIN_PASSWORD=AdminPassword123!
AUTH_ALLOW_REGISTRATION=false

JWT_ISSUER=TemplateApi
JWT_AUDIENCE=TemplateWeb

# Required only when using PostgreSQL (see docker-compose.postgres.yml):
# POSTGRES_PASSWORD=change_me_strong_postgres_password
